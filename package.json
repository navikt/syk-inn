{
    "name": "syk-inn",
    "version": "0.1.0",
    "private": true,
    "packageManager": "yarn@4.14.1",
    "engines": {
        "node": "24"
    },
    "workspaces": [
        "libs/*",
        "e2e"
    ],
    "scripts": {
        "dev": "./scripts/pre-dev.sh && concurrently --names 'next,gen'  --prefix-colors 'blue,magenta' 'yarn dev:next' 'yarn gen:watch'",
        "dev:next": "next dev --turbo | pino-pretty --messageKey=message",
        "dev:pdf": "./scripts/typst-dev.sh",
        "init:pdf": "cp $(which typst) ./typst-pdf/typst",
        "build": "./scripts/pre-build.sh && next build",
        "build:e2e": "./scripts/build-e2e.sh",
        "test": "vitest --project unit --run",
        "test:integration": "vitest --project integration --run",
        "lint": "eslint src",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "playwright": "yarn workspace e2e run playwright",
        "e2e": "./scripts/pre-e2e.sh && yarn workspace e2e run e2e",
        "e2e:dev": "yarn e2e --ui",
        "e2e:fast": "echo 'Did you run yarn build:e2e? before this?' && FAST=true yarn e2e",
        "next:e2e:start": "NEXT_PUBLIC_ASSET_PREFIX= node .next/standalone/server.js | pino-pretty --messageKey=message",
        "next:e2e:dev": "./scripts/pre-e2e-dev.sh && yarn dev:next",
        "gen": "graphql-codegen",
        "gen:watch": "graphql-codegen --watch",
        "postinstall": "husky"
    },
    "dependencies": {
        "@apollo/client": "^4.1.9",
        "@envelop/core": "^5.5.1",
        "@envelop/opentelemetry": "^9.1.1",
        "@grafana/faro-web-sdk": "^2.4.0",
        "@grafana/faro-web-tracing": "^2.4.0",
        "@graphql-tools/schema": "^10.0.33",
        "@mdx-js/loader": "^3.1.1",
        "@mdx-js/react": "^3.1.1",
        "@navikt/aksel-icons": "^8.10.3",
        "@navikt/ds-css": "^8.10.3",
        "@navikt/ds-react": "^8.10.3",
        "@navikt/ds-tailwind": "^8.10.3",
        "@navikt/fhir-mock-server": "workspace:*",
        "@navikt/helseid-mock-server": "workspace:*",
        "@navikt/next-logger": "^5.0.0",
        "@navikt/pino-logger": "^5.0.0",
        "@navikt/smart-on-fhir": "1.5.25",
        "@navikt/syk-zara": "workspace:*",
        "@navikt/texas": "^4.1.4",
        "@navikt/tsm-diagnoser": "^2026.1.13",
        "@next/mdx": "^16.2.4",
        "@opentelemetry/api": "^1.9.1",
        "@opentelemetry/core": "^2.7.1",
        "@reduxjs/toolkit": "^2.11.2",
        "@types/mdx": "^2.0.13",
        "@unleash/nextjs": "^1.6.4",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "fuse.js": "^7.3.0",
        "graphql": "^16.13.2",
        "graphql-yoga": "^5.21.0",
        "iovalkey": "^0.3.3",
        "jose": "^6.2.3",
        "motion": "^12.38.0",
        "next": "^16.2.4",
        "next-logger": "^5.0.2",
        "nextleton": "^0.6.1",
        "nuqs": "^2.8.9",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "pino-socket": "^8.0.0",
        "prom-client": "^15.1.3",
        "quick-lru": "^7.3.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-hook-form": "7.75.0",
        "react-minimal-pie-chart": "^9.1.2",
        "react-redux": "^9.2.0",
        "remark-gfm": "^4.0.1",
        "remeda": "^2.34.0",
        "rxjs": "^7.8.2",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "zod": "^4.4.2"
    },
    "devDependencies": {
        "@graphql-codegen/cli": "^6.3.1",
        "@graphql-codegen/fragment-matcher": "^6.0.1",
        "@graphql-codegen/introspection": "^5.0.2",
        "@graphql-codegen/typescript-resolvers": "^5.1.8",
        "@hookform/devtools": "^4.4.0",
        "@limegrass/eslint-plugin-import-alias": "^1.6.1",
        "@navikt/tsm-eslint-react": "^1.0.0",
        "@parcel/watcher": "^2.5.6",
        "@tailwindcss/postcss": "^4.2.4",
        "@testcontainers/kafka": "^11.14.0",
        "@testcontainers/postgresql": "^11.14.0",
        "@types/node": "^24.12.2",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@typescript/native-preview": "^7.0.0-dev.20260421.2",
        "@vitest/eslint-plugin": "^1.6.16",
        "concurrently": "^9.2.1",
        "eslint": "^9.39.4",
        "eslint-config-next": "^16.2.4",
        "husky": "^9.1.7",
        "kafkajs": "^2.2.4",
        "knip": "^6.11.0",
        "lint-staged": "^16.4.0",
        "nock": "^14.0.14",
        "oxfmt": "^0.47.0",
        "pdf-parse": "^2.4.5",
        "postcss": "^8.5.13",
        "tailwindcss": "^4.2.4",
        "testcontainers": "^11.14.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5"
    }
}
